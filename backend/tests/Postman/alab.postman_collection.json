    {
      "name": "api login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Check if the Status Code is 200 (assertOk)\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Check if the response contains the 'token' key (assertJsonStructure)\r",
              "pm.test(\"Response contains a token\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('token');\r",
              "    \r",
              "    // Optional: Save the token to a variable for future requests\r",
              "    if (jsonData.token) {\r",
              "        pm.environment.set(\"jwt_token\", jsonData.token);\r",
              "    }\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
